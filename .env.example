# MPBT Server — environment variables
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# PostgreSQL connection string.
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://mpbt:mpbt@localhost:5432/mpbt

# Server host advertised in REDIRECT packets.
# Set to the LAN/public IP of the server machine for clients connecting
# from other computers.  Leave as 127.0.0.1 for same-machine testing.
SERVER_HOST=127.0.0.1

# Server-initiated ARIES type-0x05 keepalive interval, in milliseconds.
# Set to 0 to disable.
ARIES_KEEPALIVE_INTERVAL_MS=30000

# TCP idle timeout for lobby/world sockets, in milliseconds.
# Set to 0 to disable. Keep this larger than ARIES_KEEPALIVE_INTERVAL_MS.
SOCKET_IDLE_TIMEOUT_MS=120000
